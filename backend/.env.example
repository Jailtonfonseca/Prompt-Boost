# OpenAI API Key - Obrigatório para uso local
OPENAI_API_KEY=sk-your-api-key-here

# Origins permitidos para CORS (separados por vírgula)
# Para desenvolvimento local:
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Em produção, substitua pelos domínios reais:
# CORS_ORIGINS=https://prompt-boost.yourdomain.com,https://www.prompt-boost.yourdomain.com

# Caminho do banco de dados SQLite
DATABASE_PATH=prompts.db
